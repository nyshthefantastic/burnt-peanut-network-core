<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F4F6F8"
            android:padding="12dp"
            android:text="@string/status_hint"
            android:textColor="#1B5E20"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/peer_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/peer_state_disconnected"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/peer_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="#F8F8F8"
            android:padding="8dp"
            android:text="@string/peer_list_empty"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btn_create_node"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/create_node" />

        <Button
            android:id="@+id/btn_connect_peer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/connect_peer" />

        <EditText
            android:id="@+id/input_peer_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/peer_address_hint"
            android:inputType="textNoSuggestions|textVisiblePassword" />

        <Button
            android:id="@+id/btn_connect_mac"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/connect_by_mac" />

        <Button
            android:id="@+id/btn_share_sample"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/share_sample_file" />

        <EditText
            android:id="@+id/input_file_hash"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/file_hash_hint"
            android:inputType="textNoSuggestions|textVisiblePassword"
            android:minLines="2" />

        <Button
            android:id="@+id/btn_request_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/request_file" />

        <Button
            android:id="@+id/btn_reconstruct_file"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/reconstruct_file" />

        <Button
            android:id="@+id/btn_send_bad_payload"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/send_bad_payload" />

        <Button
            android:id="@+id/btn_disconnect_peer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/disconnect_peer" />

        <Button
            android:id="@+id/btn_destroy_node"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/destroy_node" />

        <TextView
            android:id="@+id/log_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/event_log"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/event_log"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginTop="8dp"
            android:background="#10151A"
            android:fontFamily="monospace"
            android:padding="10dp"
            android:scrollbars="vertical"
            android:textColor="#E6EDF3"
            android:textIsSelectable="true"
            android:text="@string/event_log_empty"
            android:textSize="13sp" />
    </LinearLayout>
</ScrollView>
